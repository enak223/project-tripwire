<!-- Project Tripwire — Detection Rules | IDs: 101000-101999 -->
<!-- Wazuh 4.12 note: custom rules cannot chain as children of    -->
<!-- built-in rules due to file load order. overwrite="yes" used  -->
<!-- as workaround where needed.                                  -->

<group name="tripwire">

  <!-- T1003.007 — Credential Access: /proc Filesystem -->
  <rule id="101001" level="12">
    <if_sid>80700</if_sid>
    <field name="audit.key">tripwire_proc_cred</field>
    <description>Tripwire [T1003.007]: /proc/1/environ read — possible credential harvesting via environment variables</description>
    <mitre>
      <id>T1003.007</id>
    </mitre>
    <group>tripwire,credential_access,proc_filesystem</group>
  </rule>

  <!-- T1136.001 — Persistence: Local Account Creation -->
  <rule id="101002" level="10">
    <if_sid>5902</if_sid>
    <description>Tripwire [T1136.001]: New local user account created — possible persistence mechanism</description>
    <mitre>
      <id>T1136.001</id>
    </mitre>
    <group>tripwire,persistence,account_creation</group>
  </rule>

  <!-- T1070.003 — Defense Evasion: Clear History (base) -->
  <rule id="101003" level="0" noalert="1">
    <if_sid>80700</if_sid>
    <field name="audit.key">tripwire_clear_history</field>
    <description>Tripwire base: clear history key match</description>
  </rule>

  <!-- T1070.003 — Defense Evasion: Clear Command History -->
  <rule id="101004" level="9">
    <if_sid>101003</if_sid>
    <field name="audit.command" negate="yes">gvfsd-metadata|systemd|dconf|tracker|evolution|nautilus|bash|sh|vim|nano|cp|mv</field>
    <description>Tripwire [T1070.003]: .bash_history modified — possible anti-forensics activity</description>
    <mitre>
      <id>T1070.003</id>
    </mitre>
    <group>tripwire,defense_evasion,anti_forensics</group>
  </rule>

  <!-- T1053.003 — Execution/Persistence: Cron Job -->
  <rule id="101005" level="10">
    <if_sid>2832</if_sid>
    <description>Tripwire [T1053.003]: Crontab entry modified — possible scheduled task persistence</description>
    <mitre>
      <id>T1053.003</id>
    </mitre>
    <group>tripwire,execution,persistence,cron</group>
  </rule>

  <!-- T1110.001 — Credential Access: SSH Brute Force (non-existent user) -->
  <rule id="101006" level="14">
    <if_matched_sid>5712</if_matched_sid>
    <same_source_ip />
    <description>Tripwire [T1110.001]: SSH brute force — non-existent user from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>tripwire,credential_access,brute_force</group>
  </rule>

  <!-- T1110.001 — Credential Access: SSH Brute Force (valid user) -->
  <rule id="101007" level="14">
    <if_matched_sid>5720</if_matched_sid>
    <same_source_ip />
    <description>Tripwire [T1110.001]: SSH brute force — valid user from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>tripwire,credential_access,brute_force</group>
  </rule>

  <!-- T1543.003 — Persistence: Systemd Service (base) -->
  <rule id="101008" level="0" noalert="1">
    <if_sid>80700</if_sid>
    <field name="audit.key">tripwire_systemd_service</field>
    <description>Tripwire base: systemd service file change detected</description>
  </rule>

  <!-- T1543.003 — Persistence: Systemd Service -->
  <rule id="101009" level="11">
    <if_sid>101008</if_sid>
    <field name="audit.command" negate="yes">systemd|snapd|apt|dpkg|snap|update</field>
    <description>Tripwire [T1543.003]: Systemd service file created or modified by $(audit.command) — possible persistence</description>
    <mitre>
      <id>T1543.003</id>
    </mitre>
    <group>tripwire,persistence,systemd_service</group>
  </rule>

  <!-- T1562.001 — Defense Evasion: Disable Security Tools -->
  <!-- Layer 1: Wazuh agent stopped -->
  <rule id="101010" level="14">
    <if_sid>506</if_sid>
    <match>ubuntu-webserver</match>
    <description>Tripwire [T1562.001]: Wazuh agent on ubuntu-webserver stopped — possible security tool impairment</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <group>tripwire,defense_evasion,disable_tools</group>
  </rule>

  <!-- T1562.001 — Layer 2: Sudo disable security tool -->
  <!-- overwrite="yes" required — Wazuh 4.12 file load order constraint -->
  <rule id="5402" level="14" overwrite="yes">
    <if_sid>5400</if_sid>
    <match>COMMAND=.*systemctl stop.*auditd|COMMAND=.*systemctl stop.*wazuh|COMMAND=.*systemctl disable.*auditd|COMMAND=.*systemctl disable.*wazuh|COMMAND=.*systemctl mask.*auditd|COMMAND=.*systemctl mask.*wazuh</match>
    <description>Tripwire [T1562.001]: Security tool disabled via sudo — $(command)</description>
    <mitre>
      <id>T1562.001</id>
    </mitre>
    <group>tripwire,defense_evasion,disable_tools,sudo</group>
  </rule>

  <!-- Restore standard sudo-to-root detection for non-security commands -->
  <rule id="101011" level="3">
    <if_sid>5400</if_sid>
    <regex> ; USER=root ; COMMAND=| ; USER=root ; TSID=\\S+ ; COMMAND=</regex>
    <description>Successful sudo to ROOT executed.</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>sudo,pci_dss_10.2.5,pci_dss_10.2.2,gpg13_7.6,gpg13_7.8,gpg13_7.13,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,nist_800_53_AC.6,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3</group>
  </rule>

  <!-- T1046 — Discovery: Network Service Discovery -->
  <!-- overwrite="yes" required — Wazuh 4.12 file load order constraint -->
  <rule id="86601" level="10" overwrite="yes">
    <decoded_as>json</decoded_as>
    <field name="event_type">alert</field>
    <field name="source">suricata</field>
    <field name="alert.signature">Nmap|ET SCAN|portscan|port.scan</field>
    <description>Tripwire [T1046]: Network scan detected — $(alert.signature) from $(src_ip)</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>tripwire,discovery,network_scan,ids,suricata</group>
  </rule>

  <!-- Restore standard Suricata alert for non-scan signatures -->
  <rule id="101012" level="3">
    <decoded_as>json</decoded_as>
    <field name="event_type">alert</field>
    <field name="source">suricata</field>
    <description>Suricata: Alert - $(alert.signature)</description>
    <group>ids,suricata</group>
  </rule>

  <!-- T1082 — Discovery: System Information Discovery -->
  <rule id="101013" level="0" noalert="1">
    <if_sid>80700</if_sid>
    <field name="audit.key">tripwire_sysinfo</field>
    <description>Tripwire base: system info discovery command executed</description>
  </rule>

  <rule id="101014" level="5">
    <if_sid>101013</if_sid>
    <description>Tripwire [T1082]: System information discovery — $(audit.command) executed by $(audit.auid)</description>
    <mitre>
      <id>T1082</id>
    </mitre>
    <group>tripwire,discovery,sysinfo</group>
  </rule>

</group>
