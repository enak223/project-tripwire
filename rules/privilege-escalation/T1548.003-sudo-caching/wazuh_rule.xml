<!-- Tripwire Rule: T1548.003 — Abuse Elevation: Sudo and Sudo Caching -->
<!-- Detection: Built-in Wazuh rules 5402/5403 already map T1548.003         -->
<!-- Rule 101011 restores standard sudo-to-root detection alongside           -->
<!-- the T1562.001 overwrite of 5402 for security tool disabling             -->
<!-- No additional custom rule needed — built-in coverage is complete        -->

<!-- Built-in rule 5402 (level 3): Successful sudo to ROOT executed          -->
<!-- Built-in rule 5403 (level 4): First time user executed sudo             -->
<!-- Both already include: mitre.id T1548.003, tactic Privilege Escalation  -->

<!-- Tripwire restore rule that preserves T1548.003 detection:               -->
<group name="tripwire">

  <rule id="101011" level="3">
    <if_sid>5400</if_sid>
    <regex> ; USER=root ; COMMAND=| ; USER=root ; TSID=\S+ ; COMMAND=</regex>
    <description>Successful sudo to ROOT executed.</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>sudo,pci_dss_10.2.5,pci_dss_10.2.2,gpg13_7.6,gpg13_7.8,gpg13_7.13,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,nist_800_53_AC.6,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3</group>
  </rule>

</group>
