  "agent": {
    "name": "ubuntu-webserver",
    "ip": "192.168.248.139"
  },
  "data": {
    "audit": {
      "type": "SYSCALL",
      "key": "tripwire_proc_cred",
      "command": "cat",
      "exe": "/usr/bin/cat",
      "auid": "1000",
      "uid": "0",
      "syscall": "257",
      "success": "yes"
    }
  }
